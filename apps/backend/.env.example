# BiteTime billing server — copy to .env and fill in.

PORT=8787
FRONTEND_URL=http://localhost:5173

# Stripe (test mode keys for local dev)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Supabase — service role key is secret, server-only. Anon key verifies caller JWTs.
SUPABASE_URL=http://127.0.0.1:55321
SUPABASE_ANON_KEY=...
SUPABASE_SERVICE_ROLE_KEY=...

# Direct Postgres connection, for the rules that need a real transaction (supabase-js has
# none). RLS does NOT apply on this connection — it authenticates as the database owner —
# so anything using it enforces tenancy in TypeScript. Locally this is `DB_URL` from
# `supabase status`; in production it is the project's connection string.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres

# Stripe Price IDs — US default (USD). Create 2 products + 4 recurring prices, see README.
STRIPE_PRICE_BASIC_MONTHLY=price_...
STRIPE_PRICE_BASIC_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Stripe Price IDs — MY region (MYR). Optional: unset = all traffic bills USD.
# Create 4 recurring MYR prices on the same products and paste their IDs.
STRIPE_PRICE_BASIC_MONTHLY_MYR=price_...
STRIPE_PRICE_BASIC_YEARLY_MYR=price_...
STRIPE_PRICE_PRO_MONTHLY_MYR=price_...
STRIPE_PRICE_PRO_YEARLY_MYR=price_...

# Resend (trial-reminder emails). Optional locally: unset = emails are skipped.
# Production needs a verified sending domain in Resend.
RESEND_API_KEY=re_...
EMAIL_FROM=BiteTime <billing@yourdomain.com>

# Google Maps Platform (Routes + Places), on the platform's account, never a merchant's.
# Optional: unset = distance lookups fail closed.
GOOGLE_MAPS_API_KEY=
